mod main

import http
import json

type Msg {
  a:str
  b:str
}

fn slow_a() -> str = "A"
fn slow_b() -> str = "B"

fn app(req:httpReq) -> Resp {
  group {
    let ta = spawn slow_a()
    let tb = spawn slow_b()

    let a = await ta
    let b = await tb

    let body = json.encode(Msg{a:a b:b})?
    return Ok(http.json(200, body))
  }
}

fn main() -> i32 !net {
  http.serve(":8080", app)?
  return 0
}
