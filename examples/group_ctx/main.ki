mod main

import ctx
import http

fn fetch_a(c:ctx.Ctx) -> str {
  let _ = c
  return "A"
}

fn fetch_b(c:ctx.Ctx) -> str {
  let _ = c
  return "B"
}

fn app(req:http.Req) -> R[http.Resp,str] {
  let c = req.ctx
  group {
  let ta = spawn fetch_a ( c )
  let tb = spawn fetch_b ( c )
  let a = await ta
  let b = await tb
  return Ok ( http.text ( 200 , "${a}${b}" ) )
  }
}
