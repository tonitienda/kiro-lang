mod main

type Resp {
  code:i32
  body:str
}

fn text(code:i32, body:str) -> Resp {
  return Resp { code : code body : body }
}

fn route(path:str) -> Resp {
  when path
  "/health" => {
  return text ( 200 , "ok" )
  }
  _ => {
  return text ( 404 , "not found" )
  }
}

fn main() -> i32 !io {
  let res = route ( "/health" )
  print ( res.body )
  return 0
}
