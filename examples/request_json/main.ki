mod main

import http
import json

type CreateReq {
  name:str
}

fn app(req:http.Req) -> R[http.Resp,str] {
  when req.path
  "/items" => {
  let input = json.decode [ CreateReq ] ( req.body ) ?
  return Ok ( http.json ( 200 , json.encode ( input ) ? ) )
  }
  _ => {
  return Ok ( http.not_found ( ) )
  }
}
