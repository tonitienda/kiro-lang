{
  "scopeName": "source.kiro",
  "name": "Kiro",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#declarations" },
    { "include": "#numbers" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        { "name": "comment.line.documentation.kiro", "match": "^\\s*///.*$" },
        { "name": "comment.line.double-slash.kiro", "match": "//.*$" }
      ]
    },
    "strings": {
      "patterns": [
        { "name": "string.quoted.double.kiro", "begin": "\"", "end": "\"", "patterns": [
          { "name": "meta.interpolation.kiro", "match": "\\$\\{[^}]+\\}" }
        ]}
      ]
    },
    "keywords": {
      "patterns": [
        { "name": "keyword.control.kiro", "match": "\\b(mod|import|fn|type|const|let|mut|if|else|when|for|in|while|break|continue|defer|return|spawn|await|group)\\b" }
      ]
    },
    "types": {
      "patterns": [
        { "name": "storage.type.kiro", "match": "\\b(R|i32|i64|str|bool|nil)\\b|\\?[A-Za-z_][A-Za-z0-9_]*" }
      ]
    },
    "declarations": {
      "patterns": [
        { "name": "entity.name.function.kiro", "match": "\\bfn\\s+(?:\\([^)]*\\)\\s+)?([A-Za-z_][A-Za-z0-9_]*)" },
        { "name": "entity.name.type.kiro", "match": "\\btype\\s+([A-Za-z_][A-Za-z0-9_]*)" }
      ]
    },
    "numbers": {
      "patterns": [
        { "name": "constant.numeric.integer.kiro", "match": "\\b\\d+\\b" }
      ]
    },
    "operators": {
      "patterns": [
        { "name": "keyword.operator.kiro", "match": "=>|->|\\?|=|\\+|-|\\*|/|\\.|:|," },
        { "name": "punctuation.section.kiro", "match": "[{}()\\[\\]]" }
      ]
    }
  }
}
