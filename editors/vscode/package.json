{
  "name": "kiro-vscode",
  "displayName": "Kiro",
  "description": "Installable VS Code support for Kiro with syntax highlighting, diagnostics, hover, definitions, symbols, completion, and formatting via `kiro lsp`.",
  "version": "0.1.0",
  "publisher": "kiro-lang",
  "homepage": "https://github.com/tonitienda/kiro-lang",
  "repository": {
    "type": "git",
    "url": "https://github.com/tonitienda/kiro-lang.git"
  },
  "bugs": {
    "url": "https://github.com/tonitienda/kiro-lang/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Formatters"
  ],
  "keywords": [
    "kiro",
    "lsp",
    "formatter",
    "language server"
  ],
  "activationEvents": [
    "onLanguage:kiro"
  ],
  "main": "./extension.js",
  "files": [
    "extension.js",
    "language-configuration.json",
    "syntax/**",
    "README.md"
  ],
  "contributes": {
    "languages": [
      {
        "id": "kiro",
        "aliases": [
          "Kiro",
          "kiro"
        ],
        "extensions": [
          ".ki"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "kiro",
        "scopeName": "source.kiro",
        "path": "./syntax/kiro.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Kiro",
      "properties": {
        "kiro.lsp.path": {
          "type": "string",
          "default": "",
          "markdownDescription": "Optional path override for the Kiro language server executable. Leave empty for the supported default: run `kiro lsp`. Advanced users can point this at a custom `kiro` binary or a direct `kiro-lsp` binary."
        },
        "kiro.lsp.args": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "markdownDescription": "Optional extra argument override for advanced setups. Leave empty to use the built-in defaults: `[\"lsp\"]` for `kiro`, or `[]` for a direct `kiro-lsp` override."
        }
      }
    }
  },
  "scripts": {
    "lint:manifest": "node ../../scripts/verify_vscode_manifest.js",
    "package:vsix": "python3 ../../scripts/build_vsix.py . ../../dist/kiro-vscode-local.vsix",
    "verify:lsp-entrypoint": "node ../../scripts/verify_vscode_lsp_entrypoint.js"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}
