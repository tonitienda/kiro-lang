mod main

import parse

type User {
  id:i32
  email:?str
}

fn parse_id(raw:str) -> R[i32,str] {
  return parse.i32 ( raw )
}

fn maybe_email(id:i32) -> ?str {
  if id == 1 {
  return "ops@kiro.dev"
  }
  return nil
}

fn load_user(raw:str) -> R[User,str] {
  let id = parse_id ( raw ) ?
  return Ok ( User { id : id email : maybe_email ( id ) } )
}
