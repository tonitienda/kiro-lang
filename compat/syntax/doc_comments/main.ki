mod main

/// AppName is fixture doc comment.
const AppName = "compat"

/// Pair demonstrates declaration docs.
type Pair {
  left:str
  right:str
}

/// join uses the canonical block body style.
fn join(a:str, b:str) -> str {
  return "${a}-${b}"
}

fn main() -> i32 !io {
  println ( join ( AppName , "doc" ) )
  return 0
}
